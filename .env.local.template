# MOSS 环境配置模板
# 复制此文件为 .env.local 并填入真实值
# cp .env.local.template .env.local

# ===========================================
# API Keys
# ===========================================

# 火山引擎 ARK API (豆包)
ARK_API_KEY=your_api_key_here

# 阿里云 DashScope API (通义千问)
DASHSCOPE_API_KEY=your_dashscope_key_here

# 可选：其他 API
# GOOGLE_API_KEY=your_google_key
# GITHUB_TOKEN=your_github_token

# ===========================================
# MOSS 多模型配置
# ===========================================

# 核心决策模型 - 用于关键状态评估、复杂推理、论文撰写
# 推荐：qwen-max (最强推理能力)
MOSS_CORE_MODEL=qwen-max

# 日常实验模型 - 用于常规实验循环、日志分析
# 推荐：qwen-plus 或 qwen3.5-plus (性价比平衡)
MOSS_EXPERIMENT_MODEL=qwen3.5-plus

# 快速迭代模型 - 用于简单任务、快速原型验证
# 推荐：qwen-turbo (速度最快)
MOSS_FAST_MODEL=qwen-turbo

# V2 自演化专用模型 - 用于代码自修改 (需要最强代码能力)
# 推荐：qwen-max 或 qwen3.5-plus
MOSS_V2_EVOLUTION_MODEL=qwen-max

# 模型降级策略 (当主模型失败时自动降级)
MOSS_MODEL_FALLBACK=qwen3.5-plus,qwen-turbo
